# App
APP_NIPPON_RFQ_ENV=development
APP_NIPPON_RFQ_APP_NAME="RFQ Product Matching API"
APP_NIPPON_RFQ_APP_VERSION=0.1.0
APP_NIPPON_RFQ_DEBUG=false
APP_NIPPON_RFQ_DOCS_ENABLED=true

# API
APP_NIPPON_RFQ_API_PREFIX=/api/nippon-rfq
APP_NIPPON_RFQ_API_VERSION=v1

# Database
APP_NIPPON_RFQ_DATABASE_URL=sqlite:///./data/rfq_matching.db

# Storage
APP_NIPPON_RFQ_UPLOAD_DIR=./data/uploads
APP_NIPPON_RFQ_STORAGE_DIR=./data/storage
APP_NIPPON_RFQ_CSV_DIR=./data/storage/csv
APP_NIPPON_RFQ_VECTOR_DB_PATH=./data/vectors

# Matching
APP_NIPPON_RFQ_MIN_MATCH_SCORE=70.0
APP_NIPPON_RFQ_SEMANTIC_MATCH_THRESHOLD=0.85
APP_NIPPON_RFQ_HYBRID_MATCH_THRESHOLD=0.90
APP_NIPPON_RFQ_ENABLE_SEMANTIC_SEARCH=true

# AIS Manager
APP_NIPPON_RFQ_AISMBACKEND_URL=https://aismanager-stg.visiongroup.co

# LlamaParse (third-party, canonical env var)
LLAMAPARSE_API_KEY=
LLAMAPARSE_TIMEOUT=300

# OpenAI (third-party, canonical env vars)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=512
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=4000
